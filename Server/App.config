<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <system.serviceModel>
    <services>
      <service name="Server.ChargingService">
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:4000" />
          </baseAddresses>
        </host>
        <endpoint
          address="ChargingService"
          binding="netTcpBinding"
          bindingConfiguration="ChargingBinding"
          contract="Common.IChargingService" />
      </service>
    </services>
    <bindings>
      <netTcpBinding>
        <binding name="ChargingBinding"
                 maxReceivedMessageSize="10485760"
                 transferMode="Buffered"
                 receiveTimeout="00:10:00"
                 sendTimeout="00:10:00">
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
  <appSettings>
    <add key="CurrentSpikeThreshold" value="5.0" />
    <add key="ReactivePowerThreshold" value="100.0" />
  </appSettings>
</configuration>
