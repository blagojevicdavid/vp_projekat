<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <system.serviceModel>
    <client>
      <endpoint name="ChargingService"
                address="net.tcp://localhost:4000/ChargingService"
                binding="netTcpBinding"
                bindingConfiguration="ChargingBinding"
                contract="Common.IChargingService" />
    </client>
    <bindings>
      <netTcpBinding>
        <binding name="ChargingBinding"
                 maxReceivedMessageSize="10485760"
                 transferMode="Buffered"
                 receiveTimeout="00:10:00"
                 sendTimeout="00:10:00">
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
  <appSettings>
    <add key="DataPath" value="Data" />
  </appSettings>
</configuration>
